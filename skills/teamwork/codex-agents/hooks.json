{
  "description": "Teamwork hooks for Codex CLI: auto-restore on session start, check Feature state.json on stop. Note: Codex has no PreCompact/PostCompact hooks — {Feature}/state.json mechanism handles state persistence (v7.3.2).",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .agents/skills/teamwork/hooks/session-restore.sh",
            "timeout": 20
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .agents/skills/teamwork/hooks/post-stop.sh",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
