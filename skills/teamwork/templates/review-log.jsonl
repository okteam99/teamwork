// review-log.jsonl 格式定义
// 位置：{子项目路径}/docs/features/{功能目录}/review-log.jsonl
// PMO 在每个 stage 完成时追加一行，不修改已有行。
// PMO 流转前读取此文件输出 Review Dashboard。
//
// 每行一个 JSON 对象，字段定义：

{
  "stage": "plan-stage | plan-codex-review | ui-design-stage | panorama-design-stage | blueprint-stage | blueprint-codex-review | blueprint-lite-stage | dev-stage | review-stage | review-arch | review-qa | review-codex | test-stage | test-env | test-integration | test-api-e2e | browser-e2e-stage | pm-acceptance | micro-change",
  "status": "DONE | DONE_WITH_CONCERNS | NEEDS_FIX | QUALITY_ISSUE | BLOCKED | FAILED | SKIPPED | DEFERRED",
  "executor": "main-conversation | subagent | hybrid",   // v7.3 新增：执行来源

  // 时间度量（v7.3.3 新增）
  "started_at": "2026-04-15T13:45:00",   // Stage 开始时间（ISO 8601）
  "timestamp": "2026-04-15T14:30:00",    // Stage 完成时间（= completed_at，保留旧字段名向后兼容）
  "duration_minutes": 45,                 // 实际耗时（分钟，整数，四舍五入）
  "estimated_minutes": 30,                // AI 在 Execution Plan 中预估的耗时（来自 planned_execution[stage].estimated_minutes）
  "variance_pct": 50,                     // 偏差百分比 = (actual - estimated) / estimated * 100，整数，正值超预估，负值欠预估

  // 补充度量（v7.3.3 新增）
  "dispatches_count": 1,                  // 本 Stage dispatch 了几次 Subagent（主对话执行为 0）
  "retry_count": 0,                       // 本 Stage 因 QUALITY_ISSUE/NEEDS_FIX 重跑的次数
  "user_wait_seconds": 120,               // 本 Stage 等用户响应的累计秒数（区分 AI 耗时和人机协作延迟）

  "commit": "abc1234",
  "summary": "简述产出或问题",
  "artifact_path": "{Feature}/review-arch.md",          // v7.3 新增：主产物文件路径（如适用）
  "dispatch_file": "dispatch_log/005-qa-code-review.md", // v7.3 新增：如 executor=subagent 填 dispatch 文件路径
  "concerns": ["非阻塞问题1", "非阻塞问题2"],
  "batch_id": "test-batch-2026-04-16-1",   // 仅 test-stage 且 status=DEFERRED 时必填，对应 _deferred-tests.md 批次表
  "skip_reason": "...",                      // 仅 status=SKIPPED 时必填（用户提供的跳过理由）
  "stale": false
}

// 耗时字段计算规则：
// - started_at：Stage 进入时 PMO 记录（planned_execution 写入时）
// - timestamp：Stage 完成时 PMO 记录（contracts.output_satisfied = true 时）
// - duration_minutes = (timestamp - started_at) / 60，向上取整到分钟
// - estimated_minutes：从 state.json.planned_execution[stage].estimated_minutes 拷贝
// - variance_pct：重跑多次时累计（包含 retry 时间），不是单次的
// - dispatches_count：计入所有 dispatch（含 retry 重新 dispatch）
// - retry_count：Stage 内部修复循环次数（Review NEEDS_FIX / Test QUALITY_ISSUE 等）
// - user_wait_seconds：暂停点到用户确认之间的累计时长；无暂停点为 0

// stale 判定规则：
// - PMO 在写入新的 dev-stage 行时，将之前所有 review-stage / test-stage 行标记为 stale: true
//   （代码变了，之前的审查/测试结果可能失效）
// - 重跑 stage 后写入新行，旧行自然被新行覆盖（读取时取每个 stage 的最新一行）
//
// test-stage 三态说明（由 PMO「Test Stage 前置确认」的用户选择决定）：
// - 用户选择 A（立即执行）→ status = DONE / QUALITY_ISSUE / BLOCKED / DONE_WITH_CONCERNS
// - 用户选择 B（延后批量测试）→ status = DEFERRED，附 batch_id
// - 用户选择 C（跳过）→ status = SKIPPED，附 skip_reason

// Codex 交叉评审独立建行规则（v7.3.4 新增）：
// - plan-codex-review：Plan Stage 内部 4 视角评审 DONE 之后追加一行，记录 PRD 外部评审结果
// - blueprint-codex-review：Blueprint Stage 4 步内部闭环 DONE 之后追加一行，记录 TC+TECH 外部评审结果
// - review-codex：Review Stage 已有行，Code Review 外部视角
// 三者共用字段 artifact_path 指向对应 *-codex-review.md，summary 建议格式："ADOPT:N / REJECT:M / DEFER:K"
// executor 一般为 "subagent"（dispatch Codex CLI agent）；Codex CLI 不可用触发 🟢 AI 自主降级时，executor 如实填 "subagent" 或 "main-conversation"，并在 concerns 写明降级决策（选用的等效独立路径 + 独立性保证）

