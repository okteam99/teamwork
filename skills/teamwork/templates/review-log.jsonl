// review-log.jsonl 格式定义
// 位置：{子项目路径}/docs/features/{功能目录}/review-log.jsonl
// PMO 在每个 stage 完成时追加一行，不修改已有行。
// PMO 流转前读取此文件输出 Review Dashboard。
//
// 每行一个 JSON 对象，字段定义：

{
  "stage": "plan-stage | ui-design-stage | panorama-design-stage | blueprint-stage | blueprint-lite-stage | dev-stage | review-stage | review-arch | review-qa | review-codex | test-stage | test-env | test-integration | test-api-e2e | browser-e2e-stage | pm-acceptance | micro-change",
  "status": "DONE | DONE_WITH_CONCERNS | NEEDS_FIX | QUALITY_ISSUE | BLOCKED | FAILED | SKIPPED | DEFERRED",
  "executor": "main-conversation | subagent | hybrid",   // v7.3 新增：执行来源
  "timestamp": "2026-04-15T14:30:00",
  "commit": "abc1234",
  "summary": "简述产出或问题",
  "artifact_path": "{Feature}/review-arch.md",          // v7.3 新增：主产物文件路径（如适用）
  "dispatch_file": "dispatch_log/005-qa-code-review.md", // v7.3 新增：如 executor=subagent 填 dispatch 文件路径
  "concerns": ["非阻塞问题1", "非阻塞问题2"],
  "batch_id": "test-batch-2026-04-16-1",   // 仅 test-stage 且 status=DEFERRED 时必填，对应 _deferred-tests.md 批次表
  "skip_reason": "...",                      // 仅 status=SKIPPED 时必填（用户提供的跳过理由）
  "stale": false
}

// stale 判定规则：
// - PMO 在写入新的 dev-stage 行时，将之前所有 review-stage / test-stage 行标记为 stale: true
//   （代码变了，之前的审查/测试结果可能失效）
// - 重跑 stage 后写入新行，旧行自然被新行覆盖（读取时取每个 stage 的最新一行）
//
// test-stage 三态说明（由 PMO「Test Stage 前置确认」的用户选择决定）：
// - 用户选择 A（立即执行）→ status = DONE / QUALITY_ISSUE / BLOCKED / DONE_WITH_CONCERNS
// - 用户选择 B（延后批量测试）→ status = DEFERRED，附 batch_id
// - 用户选择 C（跳过）→ status = SKIPPED，附 skip_reason

// 示例（v7.3 含 executor 字段）：
// {"stage":"plan-stage","status":"DONE","executor":"main-conversation","timestamp":"2026-04-15T10:00:00","commit":"","summary":"PRD 定稿 13 条 AC","artifact_path":"{Feature}/PRD.md","concerns":[],"stale":false}
// {"stage":"blueprint-stage","status":"DONE","executor":"main-conversation","timestamp":"2026-04-15T11:00:00","commit":"","summary":"TC 15 条 + TECH.md 定稿","artifact_path":"{Feature}/TC.md","concerns":[],"stale":false}
// {"stage":"dev-stage","status":"DONE","executor":"subagent","timestamp":"2026-04-15T12:00:00","commit":"a1b2c3d","summary":"单测 47/47 通过","dispatch_file":"dispatch_log/007-rd-develop.md","concerns":[],"stale":false}
// {"stage":"review-arch","status":"DONE","executor":"main-conversation","timestamp":"2026-04-15T13:00:00","commit":"a1b2c3d","summary":"架构师 CR（主对话，怀疑者视角）","artifact_path":"{Feature}/review-arch.md","concerns":[],"stale":false}
// {"stage":"review-qa","status":"DONE","executor":"subagent","timestamp":"2026-04-15T13:05:00","commit":"a1b2c3d","summary":"QA 代码审查","dispatch_file":"dispatch_log/008-qa-code-review.md","concerns":[],"stale":false}
// {"stage":"review-codex","status":"DONE","executor":"subagent","timestamp":"2026-04-15T13:10:00","commit":"a1b2c3d","summary":"Codex 独立审查","dispatch_file":"dispatch_log/009-codex-review.md","concerns":[],"stale":false}
// {"stage":"test-env","status":"DONE","executor":"main-conversation","timestamp":"2026-04-15T13:30:00","commit":"a1b2c3d","summary":"环境健康（test-env.json 落盘）","artifact_path":"{Feature}/test-env.json","concerns":[],"stale":false}
// {"stage":"test-integration","status":"DONE","executor":"subagent","timestamp":"2026-04-15T14:00:00","commit":"a1b2c3d","summary":"集成测试 ✅","dispatch_file":"dispatch_log/010-integration-test.md","concerns":[],"stale":false}
// {"stage":"test-api-e2e","status":"DONE","executor":"subagent","timestamp":"2026-04-15T14:05:00","commit":"a1b2c3d","summary":"API E2E 脚本化 ✅","dispatch_file":"dispatch_log/011-api-e2e.md","concerns":[],"stale":false}
// {"stage":"test-stage","status":"DEFERRED","executor":"main-conversation","timestamp":"2026-04-16T09:15:00","commit":"a1b2c3d","summary":"用户选择延后批量测试","concerns":[],"batch_id":"test-batch-2026-04-16-1","stale":false}
